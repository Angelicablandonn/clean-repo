{
  "name": "nuaav-playwright-saucedemo",
  "version": "1.0.0",
  "description": "Playwright E2E automation suite for SauceDemo (Nuaav exercise)",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "keywords": ["playwright", "typescript", "e2e", "saucedemo"],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
